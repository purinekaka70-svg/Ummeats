[debug] [2026-04-08T13:00:34.218Z] <<< [apiv2][body] POST https://firebaserules.googleapis.com/v1/projects/tamuexpress-26e4a/rulesets {"name":"projects/tamuexpress-26e4a/rulesets/d482dbda-9b81-4ae7-ba34-0bdd431e6599","source":{"files":[{"content":"rules_version = '2';\nservice cloud.firestore {\n  match /databases/{database}/documents {\n    function signedIn() {\n      return request.auth != null;\n    }\n\n    function isOwner(uid) {\n      return signedIn() && request.auth.uid == uid;\n    }\n\n    // Customer flows: anyone can place and read orders from public pages.\n    match /orders/{orderId} {\n      allow read: if true;\n      allow create: if true;\n      allow update, delete: if signedIn();\n    }\n\n    match /ummaShopOrders/{orderId} {\n      allow read: if true;\n      allow create: if true;\n      allow update, delete: if signedIn();\n    }\n\n    match /feedbacks/{feedbackId} {\n      allow read: if signedIn();\n      allow create: if true;\n      allow update, delete: if signedIn();\n    }\n\n    match /ummaShopFeedbacks/{feedbackId} {\n      allow read: if signedIn();\n      allow create: if true;\n      allow update, delete: if signedIn();\n    }\n\n    match /notifications/{notificationId} {\n      allow read: if signedIn();\n      allow create: if true;\n      allow update, delete: if signedIn();\n    }\n\n    match /hotels/{hotelId} {\n      allow read: if true;\n      allow create, update, delete: if signedIn();\n    }\n\n    match /restaurants/{restaurantId} {\n      allow read: if true;\n      allow create, update, delete: if signedIn();\n    }\n\n    match /employees/{uid} {\n      allow read: if signedIn();\n      allow create, update: if isOwner(uid) || signedIn();\n      allow delete: if signedIn();\n    }\n\n    match /{document=**} {\n      allow read, write: if false;\n    }\n  }\n}\n","name":"firestore.rules"}]},"createTime":"2026-04-08T13:00:34.158511Z","metadata":{"services":["cloud.firestore"]}}
