[debug] [2026-04-20T17:09:11.140Z] <<< [apiv2][body] POST https://firebaserules.googleapis.com/v1/projects/tamuexpress-26e4a/rulesets {"name":"projects/tamuexpress-26e4a/rulesets/6eae3d73-8d29-474e-af3b-6dfdbe1a2a88","source":{"files":[{"content":"rules_version = '2';\nservice cloud.firestore {\n  match /databases/{database}/documents {\n    function signedIn() {\n      return request.auth != null;\n    }\n\n    function isAdmin() {\n      return signedIn()\n        && exists(/databases/$(database)/documents/admins/$(request.auth.uid))\n        && get(/databases/$(database)/documents/admins/$(request.auth.uid)).data.approved != false;\n    }\n\n    function isEmployee() {\n      return signedIn() && exists(/databases/$(database)/documents/employees/$(request.auth.uid));\n    }\n\n    function isEmployeeSelf(uid) {\n      return signedIn() && request.auth.uid == uid;\n    }\n\n    function isHotel() {\n      return signedIn() && request.auth.token.role == \"hotel\";\n    }\n\n    function hotelOwns(hotelId) {\n      return isHotel() && request.auth.token.hotelId == hotelId;\n    }\n\n    match /admins/{uid} {\n      allow read: if signedIn() && request.auth.uid == uid && isAdmin();\n      allow write: if false;\n    }\n\n    match /hotelAccountNames/{docId} {\n      allow read, write: if false;\n    }\n\n    match /hotelCredentials/{docId} {\n      allow read, write: if false;\n    }\n\n    match /hotels/{hotelId} {\n      allow read: if signedIn();\n      allow create: if false;\n      allow update: if isAdmin() || hotelOwns(hotelId);\n      allow delete: if isAdmin();\n    }\n\n    match /restaurants/{restaurantId} {\n      allow read: if signedIn();\n      allow create: if isAdmin() || hotelOwns(request.resource.data.hotelId);\n      allow update: if isAdmin() || hotelOwns(resource.data.hotelId);\n      allow delete: if isAdmin();\n    }\n\n    match /orders/{orderId} {\n      allow read, write: if signedIn();\n    }\n\n    match /ummaShopOrders/{orderId} {\n      allow read, write: if signedIn();\n    }\n\n    match /feedbacks/{docId} {\n      allow create: if signedIn();\n      allow read, update, delete: if isAdmin();\n    }\n\n    match /ummaShopFeedbacks/{docId} {\n      allow create: if signedIn();\n      allow read, update, delete: if isAdmin();\n    }\n\n    match /notifications/{docId} {\n      allow read, write: if signedIn();\n    }\n\n    match /employees/{uid} {\n      allow create: if isEmployeeSelf(uid);\n      allow read: if isAdmin() || isEmployeeSelf(uid);\n      allow update: if isAdmin() || isEmployeeSelf(uid);\n      allow delete: if isAdmin();\n    }\n\n    match /{document=**} {\n      allow read, write: if false;\n    }\n  }\n}\n","name":"firestore.rules"}]},"createTime":"2026-04-20T21:39:25.282591Z","metadata":{"services":["cloud.firestore"]}}
