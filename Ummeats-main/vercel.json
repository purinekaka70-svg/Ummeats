{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": null,
  "buildCommand": null,
  "outputDirectory": ".",
  "functions": {
    "api/*.js": {
      "maxDuration": 60
    }
  },
  "routes": [
    {
      "src": "/api/submit-umma-shop-order",
      "dest": "/api/submit-umma-shop-order.js"
    },
    {
      "src": "/api/send-order-notification",
      "dest": "/api/send-order-notification.js"
    },
    {
      "src": "/OneSignalSDKWorker.js",
      "dest": "/OneSignalSDKWorker.js"
    },
    {
      "src": "/OneSignalSDKUpdaterWorker.js",
      "dest": "/OneSignalSDKUpdaterWorker.js"
    },
    {
      "src": "/push/onesignal/OneSignalSDKWorker.js",
      "dest": "/push/onesignal/OneSignalSDKWorker.js"
    },
    {
      "src": "/push/onesignal/OneSignalSDKUpdaterWorker.js",
      "dest": "/push/onesignal/OneSignalSDKUpdaterWorker.js"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
